      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": { "legend": { "displayMode": "list" } },
      "targets": [
        { "expr": "sum(nginx_http_requests_total) by (code)", "legendFormat": "HTTP {{code}}", "refId": "A" }
      ],
      "title": "HTTP Status Codes",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
